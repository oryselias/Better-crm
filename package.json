{
  "name": "better-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "rundev": "bun dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "seed:test-catalog": "node scripts/sync-biochemistry-catalog.mjs && node scripts/sync-other-lab-tests-catalog.mjs",
    "e2e:setup": "node scripts/e2e/setup.mjs",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:debug": "playwright test --headed --project=chromium",
    "e2e:install": "playwright install chromium",
    "qmd:update": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/qmd.ps1 update",
    "qmd:embed": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/qmd.ps1 embed",
    "qmd:refresh": "npm run qmd:update && npm run qmd:embed"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serwist": "^9.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "25.5.2",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.1",
    "supabase": "^2.84.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
